# MedVault — Variables de entorno para scrapers
# Copiar a .env y completar con datos reales:
#   cp .env.example .env && chmod 600 .env

# ─── Ospedyc Morón ───────────────────────────────────────────────
OSPEDYC_URL=https://
OSPEDYC_USER=
OSPEDYC_PASS=
OSPEDYC_LOGIN_USER_SELECTOR=
OSPEDYC_LOGIN_PASS_SELECTOR=
OSPEDYC_LOGIN_SUBMIT_SELECTOR=
OSPEDYC_POST_LOGIN_WAIT_SELECTOR=
OSPEDYC_DATE_INPUT_SELECTOR=
OSPEDYC_DATE_CONFIRM_SELECTOR=
OSPEDYC_DATE_SET_SCRIPT=
OSPEDYC_PRE_EXTRACT_SCRIPT=
OSPEDYC_ROW_SELECTOR=
OSPEDYC_HOUR_SELECTOR=
OSPEDYC_NAME_SELECTOR=
OSPEDYC_INSURANCE_SELECTOR=
OSPEDYC_REASON_SELECTOR=
OSPEDYC_HISTORY_SELECTOR=
OSPEDYC_IGNORE_HTTPS_ERRORS=false

# ─── Hospital de Pilar ───────────────────────────────────────────
PILAR_URL=https://
PILAR_USER=
PILAR_PASS=
PILAR_LOGIN_USER_SELECTOR=
PILAR_LOGIN_PASS_SELECTOR=
PILAR_LOGIN_SUBMIT_SELECTOR=
PILAR_POST_LOGIN_WAIT_SELECTOR=
PILAR_DATE_INPUT_SELECTOR=
PILAR_DATE_CONFIRM_SELECTOR=
PILAR_DATE_SET_SCRIPT=
PILAR_PRE_EXTRACT_SCRIPT=
PILAR_ROW_SELECTOR=
PILAR_HOUR_SELECTOR=
PILAR_NAME_SELECTOR=
PILAR_INSURANCE_SELECTOR=
PILAR_REASON_SELECTOR=
PILAR_HISTORY_SELECTOR=
PILAR_IGNORE_HTTPS_ERRORS=false

# ─── Configuración general ───────────────────────────────────────
VAULT_ROOT=/home/jutopa/MedVault
HEADLESS=true
# HEADLESS=false   # Descomentar para ver el browser durante el desarrollo
